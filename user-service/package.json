{
  "name": "user-service",
  "version": "1.0.0",
  "description": "User Service microservice - Node.js + Express + TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "migrate:test-db": "node scripts/setupTestDb.js",
    "migrate:ids-to-uuid": "node scripts/migrateIdsToUuid.js"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "express-validator": "^6.15.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.10.0",
    "mysql2": "^3.3.0",
    "cookie-parser": "^1.4.7",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.1",
    "@types/morgan": "^1.9.4",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "eslint": "^8.47.0",
    "ts-node-dev": "^2.0.0",
    "ts-jest": "^29.1.0",
    "jest": "^29.6.0",
    "supertest": "^6.3.3",
    "@types/jest": "^29.5.3",
    "@types/supertest": "^2.0.12",
    "@types/cookie-parser": "^1.4.3",
    "typescript": "^5.1.6"
  }
}
